{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerId": { "type": "string" },
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "totalCost": { "type": "number" },
        "finalTotal": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["payment-required", "pending", "scheduled", "completed"] },
        "createdAt": { "type": "number" },
        "completedAt": { "type": "number" },
        "pickupTime": { "type": "number" },
        "mergeId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "quantity": { "type": "number" },
              "finalPrice": { "type": "number" },
              "isCompleted": { "type": "boolean" },
              "customName": { "type": "string" },
              "drink": { "$ref": "Drink" }
            }
          }
        }
      },
      "required": ["customerName", "total", "status", "createdAt", "items"]
    },
    "Drink": {
      "title": "Drink",
      "description": "Represents a menu item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "basePrice": { "type": "number" },
        "baseCost": { "type": "number" },
        "modifierGroups": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "category", "basePrice"]
    },
    "User": {
      "title": "User",
      "description": "Represents a system user or customer",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "kitchen", "customer"] },
        "favourites": { "type": "array", "items": { "$ref": "Drink" } },
        "hasCompletedTutorial": { "type": "boolean" },
        "birthday": { "type": "string" },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["name", "role", "loyaltyPoints"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Represents a customer in the directory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "favouriteDrinks": { "type": "array", "items": { "$ref": "Drink" } },
        "lastOrderDate": { "type": "number" },
        "notes": { "type": "string" },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["name", "loyaltyPoints"]
    },
    "Availability": {
      "title": "Availability",
      "description": "Staff availability for a specific Sunday",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["available", "unavailable", "preference"] },
        "notes": { "type": "string" }
      },
      "required": ["userId", "userName", "date", "status"]
    },
    "SundayRoster": {
      "title": "SundayRoster",
      "description": "Staff assignments for a specific Sunday",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "isPublished": { "type": "boolean" },
        "notes": { "type": "string" },
        "assignments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "role": { "type": "string" }
            }
          }
        }
      },
      "required": ["date", "isPublished", "assignments"]
    },
    "CalendarNote": {
      "title": "CalendarNote",
      "description": "A note or event pinned to the calendar",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "text": { "type": "string" },
        "color": { "type": "string", "enum": ["stone", "amber", "blue", "green", "red"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["date", "text", "color", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/orders": { "schema": "Order", "description": "Collection of all orders" },
    "/menu": { "schema": "object", "description": "Menu configuration including drinks, categories, and modifier groups" },
    "/users": { "schema": "User", "description": "User profiles and preferences" },
    "/customers": { "schema": "Customer", "description": "Global customer directory for staff" },
    "/tutorialSteps": { "schema": "array", "description": "Tutorial content" },
    "/availabilities": { "schema": "Availability", "description": "Staff availability records" },
    "/rosters": { "schema": "SundayRoster", "description": "Weekly rosters" },
    "/calendarNotes": { "schema": "CalendarNote", "description": "Calendar notes and events" }
  }
}
